# Cambria portal — local dev environment.
# Copy to .env.local and fill in values. .env.local is gitignored.
# See README.md for the full setup walkthrough.

# --- Database (required) ----------------------------------------------------
# Local dev: Postgres via the docker-compose.dev.yml in this folder.
# Prod: Cloud SQL for PostgreSQL 16 in us-west1 (per spec §5.2).
DATABASE_URL="postgresql://cambria:cambria@localhost:5432/cambria?schema=public"

# --- Auth (Phase 1 stubbed) -------------------------------------------------
# Real auth is Keycloak (per spec §3 / §13 D3). Until Keycloak is provisioned,
# the portal uses a dev-only mock auth. Set DEV_MOCK_AUTH=true in local dev only.
# In any non-local environment the portal hard-fails on startup if this is true.
DEV_MOCK_AUTH=true

# Default mock-auth role on first visit when DEV_MOCK_AUTH=true.
# One of: dme_admin | dme_staff | physician | office_staff | sales_rep
DEV_MOCK_ROLE=dme_admin

# Production-only: Keycloak OIDC issuer + client.
# KEYCLOAK_ISSUER=https://auth.petersonmedicalequipment.com/realms/cambria
# KEYCLOAK_CLIENT_ID=cambria-portal
# KEYCLOAK_CLIENT_SECRET=

# --- Audit log ---------------------------------------------------------------
# Path to the MaxMind GeoLite2-City .mmdb file used for actor_geo lookups
# (per spec §9.5). A nightly cron downloads the latest. For local dev,
# leave unset and the audit helper will skip geolocation gracefully.
# GEOLITE2_CITY_DB_PATH=/opt/geolite2/GeoLite2-City.mmdb

# --- External integrations (Phase 1 stubbed) ---------------------------------
# All of these are stubbed in local dev and only required for staging/prod.

# NPPES (free, no key) — base URL only, used at sign-up to verify NPI
NPPES_API_URL=https://npiregistry.cms.hhs.gov/api/

# OIG LEIE (free) — exclusion-list CSV, refreshed monthly
OIG_LEIE_CSV_URL=https://oig.hhs.gov/exclusions/downloadables/UPDATED.csv

# Postmark (HIPAA tier) — for transactional emails
# POSTMARK_API_TOKEN=
# POSTMARK_FROM=rx@petersonmedicalequipment.com

# Google Drive — for SWO archive (uses a service account)
# GOOGLE_DRIVE_SHARED_DRIVE_ID=
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON=

# Anthropic — for the Phase 2 roster-upload Agent SDK parser
# ANTHROPIC_API_KEY=
